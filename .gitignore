# ============================================================
# ClinicBridge — .gitignore
# Goal: never commit secrets, dependencies, build output, logs,
# uploaded files or real patient data (CSV/XLSX exports/uploads).
# ============================================================

# --- Dependencies ---
node_modules/
.pnpm-store/

# --- Build output ---
dist/
build/
*.tsbuildinfo

# --- Env files (ONLY .env.example is committed) ---
.env
.env.*
!.env.example

# --- Logs ---
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# --- Caches / tooling ---
coverage/
.nyc_output/
.turbo/
.vite/
.cache/

# --- Uploads / private storage / temp (NEVER commit user data) ---
storage/
uploads/
tmp/
temp/
*.tmp

# --- Spreadsheets & data dumps (real patient data / exports) ---
# Tabular files are treated as data, never source. If a small, anonymized
# fixture is ever needed, add it explicitly with: git add -f <file>
*.csv
*.xlsx
*.xls
*.xlsm
*.xlsb
*.zip

# --- Database dumps / backups (NEVER commit dumps, backups or restic repos) ---
# Sprint 3.5: local Restic backup/restore. Backups, dumps and the Restic
# repository contain PII and a recovery key — they must never be versioned.
*.dump
*.pgdump
*.sql
*.sql.gz
*.backup
*.bak
*.tar
*.tar.gz
*.restic
backups/
backup/
restic-repo/
.restic/

# --- Docker local volumes ---
.postgres-data/

# --- Editor / OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# --- Claude Code local overrides (machine-specific; agents/ stay tracked) ---
.claude/settings.local.json
