{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "description": "ClinicBridge backend — Express + TypeScript (Sprint 0 skeleton).",
  "license": "UNLICENSED",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:latest": "tsx scripts/db.ts migrate:latest",
    "migrate:rollback": "tsx scripts/db.ts migrate:rollback",
    "migrate:status": "tsx scripts/db.ts migrate:status"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "pino": "^9.4.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
