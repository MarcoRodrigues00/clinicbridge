# ClinicBridge — Docker build context excludes (Sprint 3.10).
# Keep the image clean: no secrets, no local deps/build, no data.

# VCS / tooling
.git
.gitignore
.claude
.vscode
.idea

# Secrets / env (NEVER copy into the image, at ANY depth; .env.example is the only
# committed env file and isn't needed at runtime either). Patterns without a slash
# only match the context root in .dockerignore, so the **/ variants are required to
# catch backend/.env, frontend/.env, etc.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Dependencies (installed fresh inside the build)
node_modules
backend/node_modules
frontend/node_modules
.pnpm-store

# Local build output (rebuilt inside the image)
dist
build
backend/dist
frontend/dist
*.tsbuildinfo

# Data / backups / uploads (must never enter the image)
backups
backup
restic-repo
.restic
storage
uploads
*.dump
*.pgdump
*.sql
*.sql.gz
*.backup
*.bak
*.tar
*.tar.gz
*.csv
*.xlsx
*.xls

# Logs / coverage / temp
logs
*.log
coverage
.nyc_output
tmp
temp

# Frontend isn't part of the backend image — but its package.json is needed so
# the pnpm workspace resolves during install. Keep only the manifest.
frontend/*
!frontend/package.json

# Docs / infra not needed at runtime
docs
infra
