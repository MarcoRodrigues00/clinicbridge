# ClinicBridge — example environment variables.
# Copy this file to .env and fill with real values for local development.
# NEVER commit .env.

# --- Application ---
NODE_ENV=development
BACKEND_PORT=3001
LOG_LEVEL=info

# --- PostgreSQL (used by backend and docker-compose) ---
POSTGRES_USER=clinicbridge
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=clinicbridge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full URL form (required by backend). Keep in sync with the values above.
DATABASE_URL=postgresql://clinicbridge:change-me-locally@localhost:5432/clinicbridge

# --- Auth (required) ---
# JWT_SECRET must be at least 48 characters of high-entropy random data.
# Generate locally with: openssl rand -hex 32   (produces 64 hex chars, ~256 bits)
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32-at-least-48-chars
JWT_EXPIRES_IN=1h

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3001

# --- CORS / security hardening (Sprint 1.5) ---
# Comma-separated list of origins allowed to call the API.
# In production, "*" is rejected — list the real frontend domain(s).
FRONTEND_ORIGIN=http://localhost:5173

# --- Auth rate limit (Sprint 1.5) ---
# Applied only to /auth/*. 20 requests per 15 minutes per IP by default.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# --- Upload (Sprint 2) ---
# Private local directory for uploaded CSV/XLSX files (never web-served).
# Files are isolated per clinic: UPLOAD_DIR/<clinica_id>/<uuid>.<ext>
UPLOAD_DIR=./storage/uploads
# Max upload size in bytes (default 5 MB).
UPLOAD_MAX_BYTES=5242880

# --- Upload rate limit (Sprint 2.1) ---
# Applied only to POST /import-files/upload. 30 uploads per 15 minutes per IP.
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30

# --- Preview limits (Sprint 2.2) ---
# Caps how much of an uploaded file is ever read back to the client.
PREVIEW_MAX_ROWS=10
PREVIEW_MAX_COLUMNS=30

# --- Full-file validation (Sprint 2.6) ---
# VALIDATION_MAX_ROWS: how many rows of the whole file are analyzed in the report.
# VALIDATION_MAX_ISSUES_RETURNED: cap on issues returned (the report is a summary).
VALIDATION_MAX_ROWS=20000
VALIDATION_MAX_ISSUES_RETURNED=100

# --- Import dry-run / simulation (Sprint 2.12) ---
# DRY_RUN_MAX_ROWS: rows analyzed per simulation.
# DRY_RUN_MAX_ISSUES_RETURNED: cap on issues returned (balanced sample).
# DRY_RUN_SAMPLE_ROWS: rows shown in the presence-only sample (no cell values).
DRY_RUN_MAX_ROWS=20000
DRY_RUN_MAX_ISSUES_RETURNED=100
DRY_RUN_SAMPLE_ROWS=20

# --- Real import (Sprint 2.16) ---
# Hard cap on rows persisted per import execution. Conservative by design.
IMPORT_MAX_ROWS=100

# --- Patient listing (Sprint 2.19) ---
# Read-only GET /patients. DEFAULT_LIMIT is used when ?limit is omitted;
# MAX_LIMIT caps any client-supplied limit so one request can't pull everything.
PATIENTS_LIST_DEFAULT_LIMIT=50
PATIENTS_LIST_MAX_LIMIT=100

# --- Duplicate detection (Sprint 2.20) ---
# Read-only GET /patients/duplicates. Caps how many patient rows are loaded per
# scan so a large clinic can't trigger an unbounded read.
DUPLICATES_SCAN_MAX_ROWS=5000

# --- Patient export (Sprint 2.21) ---
# Read-only GET /patients/export (csv/xlsx). Above this row count the export
# fails with patients_export_too_large so a single request stays bounded.
PATIENTS_EXPORT_MAX_ROWS=5000

# --- Rate limiting hardening (Sprint 2.22) ---
# Per-group, IP-keyed limiters (same <SCOPE>_RATE_LIMIT_* naming as AUTH_/UPLOAD_).
# Defaults are generous so normal MVP usage is never throttled.
# Patient reads: GET /patients, GET /patients/duplicates.
PATIENTS_RATE_LIMIT_WINDOW_MS=900000
PATIENTS_RATE_LIMIT_MAX=300
# Export (heavier): GET /patients/export.
EXPORT_RATE_LIMIT_WINDOW_MS=900000
EXPORT_RATE_LIMIT_MAX=30
# Import pipeline: preview, validate, sessions, dry-run, mark-ready, import.
IMPORT_RATE_LIMIT_WINDOW_MS=900000
IMPORT_RATE_LIMIT_MAX=120

# --- Import-file retention (Sprint 2.24) — DRY-RUN ONLY, nothing is deleted ---
# A file becomes a cleanup candidate once older than RETENTION_DAYS. DRY_RUN_MAX
# caps how many candidates GET /import-files/retention/dry-run returns.
IMPORT_FILE_RETENTION_DAYS=30
IMPORT_FILE_RETENTION_DRY_RUN_MAX=100

# --- Trust proxy (Sprint 3.2) ---
# Controls Express's `trust proxy` (whether X-Forwarded-* headers set req.ip,
# used by rate limiting and audit logs). Default 'false' = trust nothing, correct
# when the API is exposed directly. Behind a reverse proxy (Nginx/Traefik/
# Cloudflare) set the hop count, e.g. TRUST_PROXY=1, so req.ip is the real client
# IP. Accepts: false/0, true, a positive integer, or an Express preset string.
# In production, leaving this unset logs a strong warning.
TRUST_PROXY=false

# --- Rate-limit store (Sprint 3.2) ---
# 'memory' (default): per-instance in-memory counters — fine for dev / single
# instance. 'redis': shared store so counters are consistent across instances
# (required before horizontal scaling). When 'redis', REDIS_URL is REQUIRED and
# the backend FAILS FAST at startup if it cannot connect (no silent fallback).
RATE_LIMIT_STORE=memory
# Connection URL for the shared store. Only used when RATE_LIMIT_STORE=redis.
# May carry credentials — never logged. For local Redis via docker-compose:
# REDIS_URL=redis://localhost:6379
REDIS_PREFIX=clinicbridge:ratelimit:
RATE_LIMIT_REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_PORT=6379   # host port for the optional docker-compose redis service

# --- Reserved for future sprints (do not enable yet) ---
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
