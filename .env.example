# ClinicBridge — example environment variables.
# Copy this file to .env and fill with real values for local development.
# NEVER commit .env.

# --- Application ---
NODE_ENV=development
BACKEND_PORT=3001
LOG_LEVEL=info

# --- PostgreSQL (used by backend and docker-compose) ---
POSTGRES_USER=clinicbridge
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=clinicbridge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full URL form (required by backend). Keep in sync with the values above.
DATABASE_URL=postgresql://clinicbridge:change-me-locally@localhost:5432/clinicbridge

# --- Auth (required) ---
# JWT_SECRET must be at least 48 characters of high-entropy random data.
# Generate locally with: openssl rand -hex 32   (produces 64 hex chars, ~256 bits)
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32-at-least-48-chars
JWT_EXPIRES_IN=1h

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3001

# --- CORS / security hardening (Sprint 1.5 / 3.39) ---
# Comma-separated list of origins allowed to call the API.
# In production, boot fails if any origin is: "*", localhost, 127.0.0.1, or http://.
# Always use HTTPS with a real domain in production.
# dev:     FRONTEND_ORIGIN=http://localhost:5173
# staging: FRONTEND_ORIGIN=https://staging.clinicbridge.com.br
# prod:    FRONTEND_ORIGIN=https://app.clinicbridge.com.br  (HTTPS, no trailing slash)
FRONTEND_ORIGIN=http://localhost:5173

# --- Auth rate limit (Sprint 1.5) ---
# Applied only to /auth/*. 20 requests per 15 minutes per IP by default.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# --- Upload (Sprint 2) ---
# Private local directory for uploaded CSV/XLSX files (never web-served).
# Files are isolated per clinic: UPLOAD_DIR/<clinica_id>/<uuid>.<ext>
UPLOAD_DIR=./storage/uploads
# Max upload size in bytes (default 5 MB).
UPLOAD_MAX_BYTES=5242880

# --- Upload rate limit (Sprint 2.1) ---
# Applied only to POST /import-files/upload. 30 uploads per 15 minutes per IP.
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30

# --- Preview limits (Sprint 2.2) ---
# Caps how much of an uploaded file is ever read back to the client.
PREVIEW_MAX_ROWS=10
PREVIEW_MAX_COLUMNS=30

# --- Full-file validation (Sprint 2.6) ---
# VALIDATION_MAX_ROWS: how many rows of the whole file are analyzed in the report.
# VALIDATION_MAX_ISSUES_RETURNED: cap on issues returned (the report is a summary).
VALIDATION_MAX_ROWS=20000
VALIDATION_MAX_ISSUES_RETURNED=100

# --- Import dry-run / simulation (Sprint 2.12) ---
# DRY_RUN_MAX_ROWS: rows analyzed per simulation.
# DRY_RUN_MAX_ISSUES_RETURNED: cap on issues returned (balanced sample).
# DRY_RUN_SAMPLE_ROWS: rows shown in the presence-only sample (no cell values).
DRY_RUN_MAX_ROWS=20000
DRY_RUN_MAX_ISSUES_RETURNED=100
DRY_RUN_SAMPLE_ROWS=20

# --- Real import (Sprint 2.16) ---
# Hard cap on rows persisted per import execution. Conservative by design.
IMPORT_MAX_ROWS=100

# --- Patient listing (Sprint 2.19) ---
# Read-only GET /patients. DEFAULT_LIMIT is used when ?limit is omitted;
# MAX_LIMIT caps any client-supplied limit so one request can't pull everything.
PATIENTS_LIST_DEFAULT_LIMIT=50
PATIENTS_LIST_MAX_LIMIT=100

# --- Duplicate detection (Sprint 2.20) ---
# Read-only GET /patients/duplicates. Caps how many patient rows are loaded per
# scan so a large clinic can't trigger an unbounded read.
DUPLICATES_SCAN_MAX_ROWS=5000

# --- Patient export (Sprint 2.21) ---
# Read-only GET /patients/export (csv/xlsx). Above this row count the export
# fails with patients_export_too_large so a single request stays bounded.
PATIENTS_EXPORT_MAX_ROWS=5000

# --- Rate limiting hardening (Sprint 2.22) ---
# Per-group, IP-keyed limiters (same <SCOPE>_RATE_LIMIT_* naming as AUTH_/UPLOAD_).
# Defaults are generous so normal MVP usage is never throttled.
# Patient reads: GET /patients, GET /patients/duplicates.
PATIENTS_RATE_LIMIT_WINDOW_MS=900000
PATIENTS_RATE_LIMIT_MAX=300
# Export (heavier): GET /patients/export.
EXPORT_RATE_LIMIT_WINDOW_MS=900000
EXPORT_RATE_LIMIT_MAX=30
# Import pipeline: preview, validate, sessions, dry-run, mark-ready, import.
IMPORT_RATE_LIMIT_WINDOW_MS=900000
IMPORT_RATE_LIMIT_MAX=120

# --- Import-file retention (Sprint 2.24) — DRY-RUN ONLY, nothing is deleted ---
# A file becomes a cleanup candidate once older than RETENTION_DAYS. DRY_RUN_MAX
# caps how many candidates GET /import-files/retention/dry-run returns.
IMPORT_FILE_RETENTION_DAYS=30
IMPORT_FILE_RETENTION_DRY_RUN_MAX=100

# --- Readiness probe (Sprint 3.7) ---
# Max time (ms) the GET /health/ready DB check (`select 1`) waits before the
# database is reported not ready (503). Short on purpose so a proxy/orchestrator
# gets a fast answer instead of hanging on knex's long acquire timeout.
HEALTH_READY_DB_TIMEOUT_MS=2000

# --- Nginx reverse proxy local/staging (Sprint 3.9 / 3.11) ---
# Optional edge proxy (docker compose --profile edge up -d nginx), LOCAL/STAGING
# only — no real domain/WAF. Host ports (HTTP redirects to HTTPS):
# NGINX_PORT=8080          # host port -> nginx :80 (HTTP, redirects to HTTPS)
# NGINX_HTTPS_PORT=8443    # host port -> nginx :443 (HTTPS, self-signed local cert)
# Sprint 3.11: TLS is terminated at Nginx with a SELF-SIGNED LOCAL cert. Generate
# it BEFORE starting the edge profile (else Nginx fails to boot):
#   ./scripts/generate-local-nginx-cert.sh
# Certs live in infra/nginx/certs/ (gitignored) — NOT production. Production uses a
# REAL certificate (ACME/Let's Encrypt or a managed cert). Test with: curl -k ...
# When the backend runs BEHIND this Nginx, set TRUST_PROXY=1 (one hop) below so
# req.ip / rate limit / audit_logs use the real client IP from X-Forwarded-For.

# --- Trust proxy (Sprint 3.2) ---
# Controls Express's `trust proxy` (whether X-Forwarded-* headers set req.ip,
# used by rate limiting and audit logs). Default 'false' = trust nothing, correct
# when the API is exposed directly. Behind a reverse proxy (Nginx/Traefik/
# Cloudflare) set the hop count, e.g. TRUST_PROXY=1, so req.ip is the real client
# IP. Accepts: false/0, true, a positive integer, or an Express preset string.
# In production, leaving this unset logs a strong warning.
TRUST_PROXY=false

# --- Rate-limit store (Sprint 3.2) ---
# 'memory' (default): per-instance in-memory counters — fine for dev / single
# instance. 'redis': shared store so counters are consistent across instances
# (required before horizontal scaling). When 'redis', REDIS_URL is REQUIRED and
# the backend FAILS FAST at startup if it cannot connect (no silent fallback).
RATE_LIMIT_STORE=memory
# Connection URL for the shared store. Only used when RATE_LIMIT_STORE=redis.
# May carry credentials — never logged. REQUIRED when RATE_LIMIT_STORE=redis
# (boot fails otherwise). For local Redis via docker-compose:
# REDIS_URL=redis://localhost:6379
# In production with more than one instance, prefer RATE_LIMIT_STORE=redis so the
# rate limit holds across the fleet (memory mode counts per instance).
REDIS_PREFIX=clinicbridge:ratelimit:
RATE_LIMIT_REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_PORT=6379   # host port for the optional docker-compose redis service

# --- Backup/restore local (Sprint 3.5) — NOT part of the backend runtime env ---
# The Restic scripts (scripts/*.sh) read RESTIC_PASSWORD / RESTIC_REPOSITORY from
# the SHELL only. NEVER put RESTIC_PASSWORD in .env or any committed file — losing
# it makes the encrypted backup unrecoverable. See docs/backup-restore-local-runbook.md.
# Example (run in your shell, do not commit):
#   export RESTIC_PASSWORD='dev-local-only-change-me'

# --- Backup offsite Restic + S3 (Sprint 3.40) — NOT part of the backend runtime env ---
# Offsite backup scripts (scripts/{check,backup,restore}-*-offsite-restic.sh) read
# RESTIC_REPOSITORY / RESTIC_PASSWORD and AWS credentials from the SHELL or an
# IAM role/instance profile. NEVER put real values in .env or any committed file.
# In production, all of these MUST come from SSM Parameter Store / Secrets Manager
# (or, for AWS creds, from the EC2/ECS IAM role — no env vars needed).
# See docs/backup-offsite-runbook.md and docs/secrets-env-production-runbook.md.
#
# Required (set in shell or via SSM-loaded env):
#   RESTIC_REPOSITORY=s3:s3.amazonaws.com/clinicbridge-backups-prod
#     (also accepts s3:<endpoint>/<bucket>/<prefix> for MinIO/B2-S3/etc.;
#      scripts ABORT if value does not start with 's3:' — protects against local repo)
#   RESTIC_PASSWORD=<from SSM /clinicbridge/<env>/restic_password>
#     (openssl rand -base64 32; losing this = backup is unrecoverable)
#
# AWS credentials (use IAM role/instance profile on EC2/ECS — preferred):
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_SESSION_TOKEN=...               # if using STS/SSO
#   AWS_DEFAULT_REGION=sa-east-1        # recommended (avoid wrong-region latency)
#
# Optional tuning:
#   RESTIC_CACHE_DIR=~/.cache/restic    # restic's metadata cache (large repos)
#   POSTGRES_CONTAINER, POSTGRES_DB, POSTGRES_USER  # if non-defaults
#   BACKUP_WORKDIR=backups/work         # dump scratch dir (gitignored)
#   UPLOAD_DIR=./storage/uploads        # included in snapshot if it exists
#   RESTORE_DB=clinicbridge_restore_offsite_test
#     (restore drill DB; scripts abort if equal to POSTGRES_DB)
#   CLEAN_BACKUP_WORKDIR=false          # 'true' removes the dump after upload

# --- MFA / TOTP encryption key (Sprint 3.19 / 3.39) ---
# AES-256-GCM key for encrypting TOTP secrets at rest (via HKDF-SHA256).
# REQUIRED in production (boot fails if absent or < 32 chars). Optional in
# dev/test only (falls back to JWT_SECRET, which keeps dev simple but couples
# two unrelated secrets — never acceptable in production).
# Generate: openssl rand -hex 32  (64 hex chars = 256 bits of entropy)
# Store in AWS SSM Parameter Store (SecureString) — see docs/secrets-env-production-runbook.md.
# NEVER commit the real value. NEVER log it.
# WARNING: changing this key (or JWT_SECRET when unset in dev) invalidates ALL
# stored TOTP secrets — all users with MFA enabled will need to re-enroll.
# Plan a dedicated ADR/sprint before rotating this key in production.
# MFA_ENCRYPTION_KEY=

# --- Clinical read audit posture (Sprint 4.2B-1, ADR 0010 §8.2.1) ---
# Controls whether failure to persist a row in `clinical_read_audit` BLOCKS the
# clinical content response.
#   - false (default in dev/test): best-effort. Failure is logged at `error`
#     level and the read continues. ACCEPTABLE ONLY with synthetic clinical data.
#   - true:  fail-closed. Failure aborts the response with 500
#     `clinical_read_audit_unavailable`; clinical content NEVER leaves the
#     server without an audit row.
# In production (NODE_ENV=production) boot FAILS unless this is set to 'true'.
# The clinical read audit is the primary compensating control for the absence
# of column-level encryption — see ADR 0010 §13.
# dev / test:                 CLINICAL_READ_AUDIT_STRICT=false  (or unset)
# staging with synthetic data: CLINICAL_READ_AUDIT_STRICT=false  (or 'true' to drill prod posture)
# production with real data:  CLINICAL_READ_AUDIT_STRICT=true   (REQUIRED)
# CLINICAL_READ_AUDIT_STRICT=false

# --- Guided demo login (Sprint 5.0E) ---
# Enables POST /auth/demo-login, which starts a session for the pre-seeded demo
# owner of "Clínica Demo Aurora" WITHOUT accepting any credentials (the identity
# is fixed server-side; no password ever reaches the frontend).
# Off by default. The endpoint ALSO refuses whenever NODE_ENV=production, so this
# is a dev/staging-only convenience (same posture as the demo seed).
# Requires the demo dataset to be seeded first:
#   ALLOW_DEMO_SEED=true pnpm --filter backend seed:demo:full
# Accepted values: 'true' / '1' to enable; anything else (or unset) = disabled.
# ALLOW_DEMO_LOGIN=false

# --- Asaas billing gateway — SANDBOX only (Sprint 5.1E, ADR 0018 §13) ---
# COMMERCIAL layer (the SaaS charging the clinic) — NOT the clinic's financial
# module (ADR 0012). Controls the sandbox Asaas adapter + the env-gated webhook
# route POST /billing/webhooks/asaas/sandbox.
#   - 'disabled' (default): no adapter; the webhook route returns 404 and
#     outbound Asaas calls refuse.
#   - 'sandbox': enables the sandbox adapter + webhook route. Requires BOTH
#     secrets below. There is NO 'production' value — a real gateway is forbidden
#     until the production-security ADR (5.2A); setting anything but 'disabled'
#     when NODE_ENV=production FAILS startup.
# NEVER commit real keys. Use SANDBOX (fictitious) credentials only, from a
# sandbox account at https://sandbox.asaas.com. The base URL is hardcoded to the
# Asaas sandbox host in code (not env-configurable, to avoid pointing "sandbox"
# at production).
# ASAAS_ENV=disabled
# Sandbox API key (Asaas: Integrações → new key; shown once). SECRET — never log.
# IMPORTANT: Asaas keys START WITH `$` (e.g. $aact_hmlg_...). docker compose
# interpolates `$` in .env values, so escape it as `$$` when this .env is read by
# docker compose:  ASAAS_API_KEY=$$aact_hmlg_<rest-of-fake-sandbox-key>
# ASAAS_API_KEY=
# Shared token Asaas sends in the `asaas-access-token` webhook header (NOT an
# HMAC; verified with a timing-safe compare). SECRET — never log.
# ASAAS_WEBHOOK_TOKEN=

# --- Reserved for future sprints (do not enable yet) ---
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
